#: includes/class-bricks-controls.php
#: includes/class-admin-settings.php
msgid "ActiveCampaign Newsletter"
msgstr "ActiveCampaign Newsletter"

#: includes/class-bricks-controls.php
msgid "AC Form ID"
msgstr "AC-Formular-ID"

#: includes/class-bricks-controls.php
msgid "The numeric ID of your ActiveCampaign form. Find it in AC under Forms > [Form] > Integrate > embed code (the number after \"_form_\"). Lists, tags, double opt-in and automations are handled entirely by the AC form settings."
msgstr "Die numerische ID deines ActiveCampaign-Formulars. Zu finden in AC unter Formulare > [Formular] > Integrieren > Einbettungscode (die Zahl nach \"_form_\"). Listen, Tags, Double Opt-in und Automatisierungen werden vollstaendig ueber die AC-Formulareinstellungen gesteuert."

#: includes/class-bricks-controls.php
msgid "Email field"
msgstr "E-Mail-Feld"

#: includes/class-bricks-controls.php
msgid "First name field (optional)"
msgstr "Vorname-Feld (optional)"

#: includes/class-bricks-controls.php
msgid "Last name field (optional)"
msgstr "Nachname-Feld (optional)"

#: includes/class-bricks-controls.php
msgid "- none -"
msgstr "- kein -"

#: includes/class-bricks-controls.php
#: includes/class-form-handler.php
msgid "Thank you! You have been successfully subscribed."
msgstr "Danke! Du wurdest erfolgreich angemeldet."

#: includes/class-bricks-controls.php
msgid "Success message"
msgstr "Erfolgsmeldung"

#: includes/class-form-handler.php
msgid "Please provide a valid email address."
msgstr "Bitte gib eine gueltige E-Mail-Adresse an."

#: includes/class-form-handler.php
msgid "Your subscription could not be processed. Please try again later."
msgstr "Die Anmeldung konnte nicht verarbeitet werden. Bitte versuche es spaeter erneut."

#: includes/class-admin-settings.php
msgid "ActiveCampaign: Account URL"
msgstr "ActiveCampaign: Konto-URL"

#: includes/class-admin-settings.php
msgid "E.g. https://youraccount.api-us1.com — find it in AC under Settings > Developer. No API key needed."
msgstr "Z. B. https://deinaccount.api-us1.com - zu finden in AC unter Einstellungen > Entwickler. Kein API-Schluessel noetig."

#: includes/class-ac-api.php
msgid "ActiveCampaign account URL is not configured. Set it under Bricks > Settings > API keys."
msgstr "ActiveCampaign Konto-URL fehlt. Konfiguriere sie unter Bricks > Einstellungen > API-Schluessel."

#: includes/class-form-handler.php
msgid "ActiveCampaign error (admin only): %s"
msgstr "ActiveCampaign-Fehler (nur fuer Admins): %s"
